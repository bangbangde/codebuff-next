{
  "name": "codebuff",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build && pnpm build:migrate",
    "build:migrate": "node scripts/build-migration.mjs",
    "auth:schema": "auth generate --config ./lib/auth/schema-config.ts --output ./lib/db/schema.ts --adapter drizzle --dialect postgresql --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm build:migrate && node .build/migrate/migrate/index.js",
    "db:verify": "node scripts/verify-database.mjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "@better-auth/passkey": "1.6.23",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.10",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "auth": "1.6.23",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
